<engine:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:engine="UnityEngine.UIElements" xmlns:editor="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/UI%20Toolkit/MainMenuStyle.uss?fileID=7433441132597879392&amp;guid=102f65cee4c5a3f4e83ac04830fcfac3&amp;type=3#MainMenuStyle" />
    <engine:VisualElement name="SettingsScreen" style="flex-grow: 1;">
        <engine:VisualElement name="Container" style="flex-grow: 1;">
            <engine:Label text="Settings" name="Title" class="header" style="font-size: 40px; -unity-text-align: middle-center; position: relative; top: 50px; -unity-font-style: bold; color: rgb(255, 0, 210);" />
            <engine:Button text="Back" name="BackButton" class="button" />
        </engine:VisualElement>
    </engine:VisualElement>
</engine:UXML>
